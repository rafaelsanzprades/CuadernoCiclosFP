    },
    {
      "ID": "T05",
      "id_act": "ACT05",
      "Nombre_Tarea": "Evaluación de riesgos en instalaciones ICT",
      "Reto": "Elaborar un plan de prevención para el montaje de una ICT",
      "RA_Asociados": "RA6",
      "Instrumento": "Checklist de PRL",
