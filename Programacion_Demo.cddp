      "ID": "T04",
      "id_act": "ACT04",
      "Nombre_Tarea": "Diagnóstico y reparación de averías en ICT",
      "Reto": "Diagnosticar y reparar 3 averías simuladas en una instalación ICT",
      "RA_Asociados": "RA5",
      "Instrumento": "Rúbrica de práctica",
